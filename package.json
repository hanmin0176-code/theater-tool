{
  "name": "theater_tool_builder",
  "private": true,
  "scripts": {
    "dev": "npm run dev:netlify",
    "dev:vite": "vite --host 0.0.0.0",
    "dev:netlify": "npx netlify dev --offline --no-open",
    "dev:netlify:auth": "npx netlify dev --no-open",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "sample:replace": "node scripts/replace-public-template.mjs",
    "deploy:preview": "npx netlify deploy --build",
    "deploy:prod": "npx netlify deploy --build --prod"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.4",
    "@vitejs/plugin-react": "latest",
    "html-to-image": "^1.11.13",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
